# ResolveAI Environment Variables Configuration

# Application Config
ENVIRONMENT=development
JWT_SECRET=super-secret-jwt-key-replace-in-production-123456
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Database Config (PostgreSQL + pgvector)
# Use the pgvector enabled Docker image for local development
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/resolveai
DATABASE_SYNC_URL=postgresql+psycopg://postgres:postgres@localhost:5432/resolveai

# Cache & Message Broker Config (Redis)
REDIS_URL=redis://localhost:6379/0

# LLM Providers Configuration
# Provide at least one key for OpenAI or Gemini
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL_NAME=gpt-4o-mini
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL_NAME=gemini-1.5-flash

# Default LLM Provider (openai or gemini)
DEFAULT_PROVIDER=openai

# RAG Configuration
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# Observability
OPENTELEMETRY_ENDPOINT=http://localhost:4317
PROMETHEUS_PORT=8001
